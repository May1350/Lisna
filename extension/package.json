{
  "name": "extension",
  "version": "0.1.50",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "gallery": "vite --open=/src/dev-gallery/index.html",
    "prebuild": "bash scripts/sync-env-from-cdk.sh --check",
    "build": "tsc --noEmit && vite build",
    "build:sync-env": "bash scripts/sync-env-from-cdk.sh && pnpm build",
    "sync-env": "bash scripts/sync-env-from-cdk.sh",
    "verify-env": "bash scripts/sync-env-from-cdk.sh --check",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.1.40",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@xyflow/react": "^12.10.2",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "tailwindcss": "3",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
