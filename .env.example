# Backend
DATABASE_URL=
JWT_SECRET=
# LLM curator — defaults to OpenAI gpt-4o-mini (with gpt-4o fallback).
# Setting ANTHROPIC_API_KEY alone does NOT auto-switch; the curator
# only uses Claude when `CURATOR_PROVIDER=anthropic` is explicitly
# set (see backend/src/lib/curator.ts selectModels for rationale).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Optional curator overrides:
#   CURATOR_PROVIDER  = 'anthropic' to swap to Claude (default omits = openai)
#   CURATOR_PRIMARY   = override the per-provider primary model id
#                       (defaults: openai → gpt-4o-mini, anthropic → claude-haiku-4-5)
#   CURATOR_FALLBACK  = override the per-provider fallback model id
#                       (defaults: openai → gpt-4o, anthropic → claude-haiku-4-5)
CURATOR_PROVIDER=
CURATOR_PRIMARY=
CURATOR_FALLBACK=
# STT — Groq Whisper Large-v3 (free-tier ~8 h/day). Falls back to
# OpenAI Whisper API in stt.ts if Groq is unavailable.
GROQ_API_KEY=
GOOGLE_GENAI_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
# Public marketing site URL — used by Stripe redirect URLs and the
# Pro upsell links. Production = https://lisna.jp.
PUBLIC_WEB_BASE_URL=https://lisna.jp
S3_BUCKET=
AWS_REGION=ap-northeast-1

# Extension (build-time)
VITE_API_BASE_URL=
VITE_WS_URL=
# Lambda Function URL for /v1/session/curate — bypasses API Gateway
# HTTP API's hard 30 s integration timeout. Optional; SW falls back
# to VITE_API_BASE_URL/v1/session/curate when unset.
VITE_CURATE_URL=
VITE_GOOGLE_OAUTH_CLIENT_ID=
VITE_STRIPE_PUBLIC_KEY=
