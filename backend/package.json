{
  "name": "backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx watch src/handlers/health.ts",
    "cdk": "cdk --app 'tsx infra/bin/app.ts'",
    "deploy": "pnpm cdk deploy --all --require-approval never",
    "synth": "pnpm cdk synth",
    "migrate": "tsx src/lib/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1037.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/client-secrets-manager": "^3.1037.0",
    "@aws-sdk/client-sns": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@google/generative-ai": "^0.24.1",
    "aws-cdk-lib": "^2.251.0",
    "constructs": "^10.6.0",
    "jose": "^6.2.2",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "shared": "workspace:*",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "^3.1045.0",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "aws-cdk": "^2.1119.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.6"
  }
