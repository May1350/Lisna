{
  "name": "@lisna/desktop",
  "version": "0.1.4",
  "private": true,
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:sidecar": "bash sidecar/scripts/build.sh",
    "test:sidecar": "bash sidecar/scripts/build.sh test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "bash scripts/test-with-cleanup.sh",
    "test:e2e": "playwright test",
    "package": "pnpm build:sidecar && pnpm build && electron-builder --mac --publish never",
    "smoke:main": "tsx ci/smoke-main-boot.ts",
    "verify": "tsx ci/gates.ts && pnpm typecheck && pnpm lint && pnpm test && bash scripts/verify-no-zombies.sh && pnpm build && pnpm smoke:main",
    "eval:notes": "tsx scripts/eval-notes.ts",
    "eval:stt": "tsx scripts/eval-stt.ts",
    "eval:judge-swap": "tsx scripts/eval-judge-swap.ts",
    "eval:spike-0.2": "tsx scripts/score-spike-0.2.ts"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^39.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "tsx": "^4.21.0",
    "typescript": "~5.5.0",
    "typescript-eslint": "^8",
    "vite": "^5.4.0",
    "vitest": "^2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "openai": "^6.34.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^3"
  }
}
