root ::= LectureNote
LectureNote-schemaVersion ::= json-number
LectureNote-family ::= "\"lecture\""
LectureNote-title ::= json-string
LectureNote-tldr ::= json-string
LectureNote-sections-elem-heading ::= json-string
LectureNote-sections-elem-ts ::= json-number
LectureNote-sections-elem-summary ::= json-string
LectureNote-sections-elem-key-terms-elem-term ::= json-string
LectureNote-sections-elem-key-terms-elem-definition ::= json-string
LectureNote-sections-elem-key-terms-elem-ts ::= json-number
LectureNote-sections-elem-key-terms-elem ::= "{" ws "\"term\"" ":" ws LectureNote-sections-elem-key-terms-elem-term "," ws "\"definition\"" ":" ws LectureNote-sections-elem-key-terms-elem-definition "," ws "\"ts\"" ":" ws LectureNote-sections-elem-key-terms-elem-ts  ws "}"
LectureNote-sections-elem-key-terms ::= "[" ws (LectureNote-sections-elem-key-terms-elem (ws "," ws LectureNote-sections-elem-key-terms-elem)*)? ws "]"
LectureNote-sections-elem-extras-elem-v0-type ::= "\"procedure_steps\""
LectureNote-sections-elem-extras-elem-v0-items-elem-text ::= json-string
LectureNote-sections-elem-extras-elem-v0-items-elem-order ::= json-number
LectureNote-sections-elem-extras-elem-v0-items-elem ::= "{" ws "\"text\"" ":" ws LectureNote-sections-elem-extras-elem-v0-items-elem-text ("," ws "\"order\"" ":" ws LectureNote-sections-elem-extras-elem-v0-items-elem-order)? ws "}"
LectureNote-sections-elem-extras-elem-v0-items ::= "[" ws (LectureNote-sections-elem-extras-elem-v0-items-elem (ws "," ws LectureNote-sections-elem-extras-elem-v0-items-elem)*)? ws "]"
LectureNote-sections-elem-extras-elem-v0 ::= "{" ws "\"type\"" ":" ws LectureNote-sections-elem-extras-elem-v0-type "," ws "\"items\"" ":" ws LectureNote-sections-elem-extras-elem-v0-items  ws "}"
LectureNote-sections-elem-extras-elem-v1-type ::= "\"formula\""
LectureNote-sections-elem-extras-elem-v1-items-elem-expression ::= json-string
LectureNote-sections-elem-extras-elem-v1-items-elem-label ::= json-string
LectureNote-sections-elem-extras-elem-v1-items-elem ::= "{" ws "\"expression\"" ":" ws LectureNote-sections-elem-extras-elem-v1-items-elem-expression ("," ws "\"label\"" ":" ws LectureNote-sections-elem-extras-elem-v1-items-elem-label)? ws "}"
LectureNote-sections-elem-extras-elem-v1-items ::= "[" ws (LectureNote-sections-elem-extras-elem-v1-items-elem (ws "," ws LectureNote-sections-elem-extras-elem-v1-items-elem)*)? ws "]"
LectureNote-sections-elem-extras-elem-v1 ::= "{" ws "\"type\"" ":" ws LectureNote-sections-elem-extras-elem-v1-type "," ws "\"items\"" ":" ws LectureNote-sections-elem-extras-elem-v1-items  ws "}"
LectureNote-sections-elem-extras-elem ::= LectureNote-sections-elem-extras-elem-v0 | LectureNote-sections-elem-extras-elem-v1
LectureNote-sections-elem-extras ::= "[" ws (LectureNote-sections-elem-extras-elem (ws "," ws LectureNote-sections-elem-extras-elem)*)? ws "]"
LectureNote-sections-elem ::= "{" ws "\"heading\"" ":" ws LectureNote-sections-elem-heading "," ws "\"ts\"" ":" ws LectureNote-sections-elem-ts "," ws "\"summary\"" ":" ws LectureNote-sections-elem-summary "," ws "\"key_terms\"" ":" ws LectureNote-sections-elem-key-terms ("," ws "\"extras\"" ":" ws LectureNote-sections-elem-extras)? ws "}"
LectureNote-sections ::= "[" ws (LectureNote-sections-elem (ws "," ws LectureNote-sections-elem)*)? ws "]"
LectureNote ::= "{" ws "\"schemaVersion\"" ":" ws LectureNote-schemaVersion "," ws "\"family\"" ":" ws LectureNote-family "," ws "\"title\"" ":" ws LectureNote-title "," ws "\"sections\"" ":" ws LectureNote-sections ("," ws "\"tldr\"" ":" ws LectureNote-tldr)? ws "}"
ws ::= [ \t\n]*
json-string ::= "\"" char* "\""
char ::= [^"\\] | "\\" ["\\/bfnrt]
json-number ::= "-"? ("0" | [1-9] [0-9]*) ("." [0-9]+)? ([eE] [-+]? [0-9]+)?