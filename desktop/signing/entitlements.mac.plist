<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- electron-builder defaults (Electron JIT + native modules: keytar
         .node addon, sidecar dylibs are ad-hoc signed) — keep all three. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- P0 2026-06-11 — hardened-runtime apps are DENIED microphone access
         at the OS level without this entitlement: no TCC prompt ever fires
         (the app never appears in Privacy & Security → Microphone) and
         Chromium's getUserMedia returns a SILENT stream instead of an error,
         so every chunk dies in the renderer silence gate → "0 segments".
         Dev mode and terminal-launched runs masked this via the responsible
         process's (Terminal's) mic permission. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
  </dict>
</plist>
