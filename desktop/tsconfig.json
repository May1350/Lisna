{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "typeRoots": ["./node_modules/@types"],
    "paths": { "@shared/*": ["./src/shared/*"] }
  },
  "include": ["src/**/*"]
}
